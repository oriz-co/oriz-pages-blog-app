---
import { getCollection } from "astro:content";
import BookmarkButton from "../components/BookmarkButton.astro";
import GiscusComments from "../components/GiscusComments.astro";
import RecentlyViewed from "../components/RecentlyViewed.astro";
import Recommendations from "../components/Recommendations.astro";
import ShareButtons from "../components/ShareButtons.astro";
import TableOfContents from "../components/TableOfContents.astro";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags: string[];
  category: string;
  readingTime?: string;
  headings: Array<{ depth: number; slug: string; text: string }>;
  slug: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags,
  category,
  readingTime,
  headings,
} = Astro.props;

const { slug } = Astro.props;
const allPosts = await getCollection("blog", ({ data }) => !data.draft);

// Series detection and pagination
const isPart = slug.includes("/");
const seriesSlug = isPart ? slug.split("/")[0] : null;

let seriesPosts = [];
let seriesTitle = "";
let sortedSeriesParts = [];
let currentPartIndex = -1;
let prevPost = null;
let nextPost = null;

if (seriesSlug) {
  seriesPosts = allPosts.filter((p) => p.id.startsWith(`${seriesSlug}/`));
  
  const indexPost = seriesPosts.find(
    (p) => p.id === `${seriesSlug}/index` || p.id.endsWith("/index")
  );
  
  const parts = seriesPosts.filter(
    (p) => p.id !== `${seriesSlug}/index` && !p.id.endsWith("/index")
  );
  
  sortedSeriesParts = parts.sort((a, b) => {
    const partA = a.data.part;
    const partB = b.data.part;
    if (partA != null && partB != null) {
      return Number(partA) - Number(partB);
    }
    return a.id.localeCompare(b.id, undefined, {
      numeric: true,
      sensitivity: "base",
    });
  });
  
  const representative = indexPost ?? sortedSeriesParts[0];
  seriesTitle = representative?.data.series || indexPost?.data.title || "Blog Series";
  
  currentPartIndex = sortedSeriesParts.findIndex((p) => p.id === slug);
  prevPost = currentPartIndex > 0 ? sortedSeriesParts[currentPartIndex - 1] : null;
  nextPost = currentPartIndex !== -1 && currentPartIndex < sortedSeriesParts.length - 1 
    ? sortedSeriesParts[currentPartIndex + 1] 
    : null;
}

const formattedDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedUpdatedDate = updatedDate?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={title} description={description} ogImage={heroImage}>
  <article class="max-w-screen-2xl mx-auto px-4 sm:px-6 py-12">
    <header class="mb-10 animate-fade-in">
      <div class="flex items-center gap-3 mb-4 text-sm text-text-tertiary">
        <a
          href={`/categories/${category.toLowerCase().replace(/[\s\/]+/g, "-")}`}
          class="px-2.5 py-1 rounded-md bg-accent/10 text-accent-light hover:bg-accent/20 transition-colors"
        >
          {category}
        </a>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {readingTime && <span>· {readingTime}</span>}
      </div>

      <h1
        class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight leading-tight mb-4"
      >
        {title}
      </h1>

      <p class="text-lg text-text-secondary leading-relaxed max-w-2xl">
        {description}
      </p>

      {
        updatedDate && (
          <p class="text-sm text-text-tertiary mt-2">
            Last updated: {formattedUpdatedDate}
          </p>
        )
      }
    </header>

    {
      heroImage && (
        <div class="mb-10 rounded-2xl overflow-hidden border border-border">
          <img
            src={heroImage}
            alt={title}
            class="w-full h-auto object-cover"
            loading="eager"
          />
        </div>
      )
    }

    <div class="flex gap-12">
      {
        headings && headings.length > 0 && (
          <aside class="hidden lg:block w-56 shrink-0">
            <div class="sticky top-24 max-h-[calc(100vh-8rem)] overflow-y-auto pr-4 scrollbar-hide">
              <TableOfContents headings={headings} />
            </div>
          </aside>
        )
      }

      <div class="flex-1 min-w-0">
        {
          seriesSlug && sortedSeriesParts.length > 0 && (
            <div class="glass-card mb-8 p-6 rounded-2xl border border-border bg-bg-card/30">
              <div class="flex items-center justify-between flex-wrap gap-4 mb-4">
                <div class="flex items-center gap-3">
                  <span class="text-2xl">📖</span>
                  <div>
                    <h3 class="text-sm font-semibold text-text-primary">
                      Part of Series:{" "}
                      <a href={`/series/${seriesSlug}`} class="text-accent-light hover:underline font-bold">
                        {seriesTitle}
                      </a>
                    </h3>
                    <p class="text-xs text-text-tertiary">
                      Part {currentPartIndex + 1} of {sortedSeriesParts.length}
                    </p>
                  </div>
                </div>
              </div>
              
              <details class="group">
                <summary class="text-xs font-semibold text-text-secondary hover:text-accent-light cursor-pointer list-none flex items-center gap-1 select-none">
                  <span>View All Parts</span>
                  <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <ol class="mt-3 space-y-2 border-t border-border/50 pt-3 text-sm">
                  {sortedSeriesParts.map((part, index) => {
                    const isCurrent = part.id === slug;
                    return (
                      <li class="flex items-center gap-2">
                        <span class={`w-5 h-5 rounded-full flex items-center justify-center text-xs font-bold ${isCurrent ? 'bg-accent/20 text-accent-light' : 'bg-bg-tertiary text-text-tertiary'}`}>
                          {index + 1}
                        </span>
                        {isCurrent ? (
                          <span class="font-medium text-text-primary flex-1">
                            {part.data.title} <span class="text-xs text-accent-light font-normal">(You are here)</span>
                          </span>
                        ) : (
                          <a href={`/blog/${part.id}`} class="text-text-secondary hover:text-accent-light hover:underline flex-1 transition-colors">
                            {part.data.title}
                          </a>
                        )}
                      </li>
                    );
                  })}
                </ol>
              </details>
            </div>
          )
        }

        <div class="prose-content">
          <slot />
        </div>

        {
          seriesSlug && (prevPost || nextPost) && (
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-12 mb-8">
              {prevPost ? (
                <a href={`/blog/${prevPost.id}`} class="glass-card p-4 rounded-xl border border-border flex flex-col items-start gap-1 group hover:-translate-y-0.5 transition-all">
                  <span class="text-xs text-text-tertiary font-medium">← Previous Part</span>
                  <span class="text-sm font-semibold text-text-primary group-hover:text-accent-light line-clamp-1 transition-colors">
                    {prevPost.data.title}
                  </span>
                </a>
              ) : (
                <div />
              )}
              
              {nextPost ? (
                <a href={`/blog/${nextPost.id}`} class="glass-card p-4 rounded-xl border border-border flex flex-col items-end gap-1 group hover:-translate-y-0.5 transition-all text-right">
                  <span class="text-xs text-text-tertiary font-medium font-semibold">Next Part →</span>
                  <span class="text-sm font-semibold text-text-primary group-hover:text-accent-light line-clamp-1 transition-colors">
                    {nextPost.data.title}
                  </span>
                </a>
              ) : (
                <div />
              )}
            </div>
          )
        }

        <div class="mt-10 pt-8 border-t border-border">
          <div class="flex flex-wrap gap-2 mb-8">
            {
              tags.map((tag) => (
                <a
                  href={`/tags/${tag.toLowerCase().replace(/\s+/g, "-")}`}
                  class="px-3 py-1.5 text-sm rounded-lg bg-bg-tertiary text-text-secondary hover:text-text-primary hover:bg-bg-card transition-all border border-border"
                >
                  #{tag}
                </a>
              ))
            }
          </div>

          <div class="flex items-center justify-between flex-wrap gap-4">
            <ShareButtons title={title} url={Astro.url.href} />
            <BookmarkButton />
          </div>
        </div>

        <div class="mt-12">
          <GiscusComments />
        </div>

        <RecentlyViewed />

        <Recommendations
          currentSlug={slug}
          currentTags={tags}
          allPosts={allPosts}
        />
      </div>
    </div>
  </article>

  <!-- Client-side Mermaid diagrams rendering script -->
  <script is:inline>
    (function() {
      // Find all potential Astro-wrapped Mermaid code blocks
      const blocks = document.querySelectorAll('pre code.language-mermaid, pre[data-language="mermaid"], .language-mermaid');
      
      if (blocks.length > 0) {
        // Dynamically import the Mermaid ESM library from CDN
        import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs')
          .then(({ default: mermaid }) => {
            mermaid.initialize({
              startOnLoad: false,
              theme: 'dark',
              securityLevel: 'loose',
              themeVariables: {
                background: 'transparent',
                primaryColor: '#a855f7',
                primaryTextColor: '#f8f9fa',
                lineColor: '#6b7280',
              }
            });

            blocks.forEach((block, idx) => {
              const pre = block.tagName === 'CODE' ? block.parentElement : block;
              
              if (pre.dataset.mermaidProcessed) return;
              pre.dataset.mermaidProcessed = 'true';

              const codeText = block.textContent;

              const container = document.createElement('div');
              container.className = 'mermaid';
              container.id = `mermaid-diagram-${idx}`;
              container.style.display = 'flex';
              container.style.justifyContent = 'center';
              container.style.margin = '2.5rem 0';
              container.style.background = 'rgba(15, 10, 25, 0.4)';
              container.style.padding = '1.5rem';
              container.style.borderRadius = '1rem';
              container.style.border = '1px solid rgba(255, 255, 255, 0.08)';
              container.style.overflowX = 'auto';
              container.textContent = codeText;

              pre.parentNode.replaceChild(container, pre);
            });

            mermaid.run();
          })
          .catch(err => console.error('Failed to load Mermaid CDN:', err));
      }
    })();
  </script>
</BaseLayout>

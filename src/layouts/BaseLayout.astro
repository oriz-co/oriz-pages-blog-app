---
/*
 * BaseLayout — single page shell for every oriz-blog route (v2).
 *
 * Cream paper, cobalt accent, Fraunces display. No sidebar (the v1
 * SiteSidebar is gone — chrome is just header + footer).
 *
 * Family-anchor pattern. Sister sites copy this skeleton; oriz-blog adds
 * Fraunces (variable, opsz + SOFT axes) on top of the family-default
 * Inter Tight + JetBrains Mono.
 */
import '~/styles/global.css'
import '~/styles/oriz-ui-overrides.css'
import 'katex/dist/katex.min.css'
import Layout from '@chirag127/astro-chrome/Layout.astro'
import HeaderControls from '~/components/HeaderControls'
import FeedDiscovery from '~/components/FeedDiscovery.astro'
import { ClientRouter } from 'astro:transitions'

interface Props {
  title?: string
  description?: string
  canonical?: string
  noindex?: boolean
  jsonLd?: Record<string, unknown> | Record<string, unknown>[]
  image?: string
  type?: 'website' | 'article'
  pubDate?: Date
  updatedDate?: Date
  /** Kept for compatibility with v1 routes — v2 has no sidebar so this is a no-op. */
  hideSidebar?: boolean
}

const {
  title = 'oriz / blog',
  description = "An engineer's working notebook. Long-form writing on engineering, finance, and books — by Chirag Singhal.",
  canonical = `https://blog.oriz.in${Astro.url.pathname}`,
  noindex = false,
  jsonLd,
  image,
  type = 'website',
  pubDate,
  updatedDate,
} = Astro.props

const adsenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT
const beaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN
const ga4Id = import.meta.env.PUBLIC_GA4_ID

const ogImage = image ? new URL(image, 'https://blog.oriz.in').toString() : undefined
const bottomBarActions = [
  { icon: '⌂', label: 'Home', href: 'https://oriz.in/' },
  { icon: '✎', label: 'Blog', href: '/' },
  { icon: '⚒', label: 'Tools', href: 'https://oriz.in/tools/' },
  { icon: 'ℹ', label: 'About', href: '/about/' },
]
import '@chirag127/astro-shell/tokens.css'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="oriz / blog" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {type === 'article' && pubDate && (
      <meta property="article:published_time" content={pubDate.toISOString()} />
    )}
    {type === 'article' && updatedDate && (
      <meta property="article:modified_time" content={updatedDate.toISOString()} />
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@chirag127" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#fbfaf7" />
    <FeedDiscovery />

    {/*
      Type stack — Fraunces (variable, opsz + SOFT) for display + drop-cap;
      Source Serif 4 for body; Inter Tight for chrome; JetBrains Mono for
      numerals and the series spine.
    */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT@9..144,300..700,0..100&family=Source+Serif+4:opsz,ital,wght@8..60,0,400;8..60,0,600;8..60,1,400&family=Inter+Tight:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <ClientRouter />

    {jsonLd && (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])}
      />
    )}

    {adsenseClient && (
      <script
        is:inline
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsenseClient}`}
        crossorigin="anonymous"
      />
    )}

    {beaconToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${beaconToken}"}`}
      />
    )}

    {ga4Id && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`} />
        <script is:inline define:vars={{ ga4Id }}>
          {`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config',ga4Id);`}
        </script>
      </>
    )}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Layout bottomBarActions={bottomBarActions}>
      <HeaderControls client:idle slot="header-actions" />
      <slot />
    </Layout>

    <script>
      if ('serviceWorker' in navigator && location.hostname !== 'localhost') {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {})
        })
      }
    </script>
  </body>
</html>

# ============================================
# Environment Variables for blog.oriz.in
# ============================================
# Copy this file to .env and fill in the values.
# For Cloudflare Pages, set these under:
#   Dashboard → Workers & Pages → blog-hunter → Settings → Environment variables
# ============================================

# --- Core Site Configuration ---
PUBLIC_SITE_URL=https://blog.oriz.in

# --- Cloudflare Analytics ---
# Cloudflare Web Analytics Token (from Workers & Pages → Web Analytics)
PUBLIC_CF_BEACON=

# ============================================
# MULTI-PLATFORM BLOG SYNDICATION CREDENTIALS
# ============================================

# --- Dev.to (Forem API v1) ---
# Retrieve from: Settings → Account → API Keys
DEVTO_API_KEY=your_devto_api_key_here

# --- Hashnode (GraphQL API v2) ---
# Personal Access Token: Account Settings → Developer
HASHNODE_API_KEY=your_hashnode_pat_here
# Publication ID: Blog Dashboard → Settings
HASHNODE_PUBLICATION_ID=your_hashnode_publication_id_here

# --- Medium (REST API) ---
# Integration Token: Settings → Security → Integration Tokens
MEDIUM_INTEGRATION_TOKEN=your_medium_integration_token_here

# --- WordPress (REST API) ---
# WordPress site base URL (e.g. free hosted tier: https://yourblog.wordpress.com)
WORDPRESS_URL=https://your-wordpress-site-url
# Account username
WORDPRESS_USERNAME=your_wordpress_username
# Application Password: Users → Profile → Application Passwords
WORDPRESS_APP_PASSWORD=your_wordpress_app_password_here

# --- Google Blogger (Blogger API v3) ---
# Blog ID: blogger.com Dashboard URL (e.g., blogID=xxxx)
BLOGGER_BLOG_ID=your_blogger_blog_id_here
# Google Console Credentials: console.cloud.google.com
BLOGGER_CLIENT_ID=your_blogger_google_client_id_here
# Google Console Client Secret
BLOGGER_CLIENT_SECRET=your_blogger_google_client_secret_here
# Refresh Token resolved via OAuth 2.0 Playground or Console
BLOGGER_REFRESH_TOKEN=your_blogger_google_refresh_token_here

# --- X / Twitter (Twitter API v2) ---
# API / Consumer Key: developer.x.com Portal
X_CONSUMER_KEY=your_x_consumer_key_here
# API / Consumer Secret: developer.x.com Portal
X_CONSUMER_SECRET=your_x_consumer_secret_here
# User Access Token: App Settings (OAuth 1.0a User Context)
X_ACCESS_TOKEN=your_x_access_token_here
# User Access Token Secret: App Settings
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here

# ============================================
# DEPLOYMENT SECRETS (GitHub Actions Secrets)
# ============================================
# Do NOT save these here. Place them directly in GitHub Repository Secrets:
#   CLOUDFLARE_ACCOUNT_ID  → dash.cloudflare.com → URL / Overview sidebar
#   CLOUDFLARE_API_TOKEN   → dash.cloudflare.com/profile/api-tokens
# ============================================
